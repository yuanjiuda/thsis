@article{luoNovelAngleDelayDopplerEstimation2025,
  title = {A {{Novel Angle-Delay-Doppler Estimation Scheme}} for {{AFDM-ISAC System}} in {{Mixed Near-Field}} and {{Far-Field Scenarios}}},
  author = {Luo, Yirui and Guan, Yong Liang and Ge, Yao and Gonz{\'a}lez G, David and Yuen, Chau},
