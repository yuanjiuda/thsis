@article{singhPerformanceEnhancement1122022,
  title = {Performance Enhancement of 112 {{Gbps UWOC}} Link by Mitigating the Air Bubbles Induced Turbulence with Coherent Detection {{MIMO DP-16QAM}} and Advanced Digital Signal Processing},
  author = {Singh, Mandeep and Singh, Maninder Lal and Singh, Rajandeep},
  year = 2022,
