@article{liRecentProgressUnderwater2025,
  title = {Recent {{Progress}} on {{Underwater Wireless Communication Methods}} and {{Applications}}},
  author = {Li, Zhe and Li, Weikun and Sun, Kai and Fan, Dixia and Cui, Weicheng},
  year = 2025,
